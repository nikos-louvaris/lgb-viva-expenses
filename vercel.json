{
  "version": 2,
  "functions": {
    "api/*.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/elorus-push?all=1", "schedule": "0 19 * * *" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate, max-age=0" }
      ]
    }
  ]
}
